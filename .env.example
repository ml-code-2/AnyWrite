# AnyWrite Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom)
ANYWRITE_LLM_PROVIDER=openai

# API Base URL (OpenAI-compatible endpoint)
ANYWRITE_LLM_BASE_URL=https://api.openai.com/v1

# API Key
ANYWRITE_LLM_API_KEY=sk-your-key-here

# Model name
ANYWRITE_LLM_MODEL=gpt-4o

# Notifications (optional)
ANYWRITE_TELEGRAM_BOT_TOKEN=
ANYWRITE_TELEGRAM_CHAT_ID=
ANYWRITE_FEISHU_WEBHOOK_URL=
ANYWRITE_WECOM_WEBHOOK_URL=
